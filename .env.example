# Neon pooled connection string (used at runtime by the app)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Neon direct (non-pooled) connection string (used by Prisma for migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-a-long-random-string"

# Seed admin credentials
ADMIN_EMAIL="admin@medha.org.in"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Medha Admin"
